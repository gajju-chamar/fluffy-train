#!/bin/bash
### Shinobu Music Bot Installer

pprint(){
    cred='\033[0;31m'
    cgreen='\033[0;32m'
    cyellow='\033[0;33m'
    cblue='\033[0;34m'
    cpurple='\033[0;35m'
    eval "export color='$cpurple'"
    [ ! -z $2 ] && eval "export color=\"\$$2\""
    printf "$color $1"
}

color_reset(){ printf '\033[0;37m';}

yesnoprompt(){
    old_stty_cfg=$(stty -g)
    stty raw -echo ; answer=$(head -c 1)
    stty $old_stty_cfg
    echo "$answer" | grep -iq "^y"
}

update(){
    pprint "\n\nUpdating package list.. "
    sudo apt update 2>&1 | grep "can be upgraded" &>/dev/null
    if [ $? -eq 0 ]; then
        pprint "UPDATE AVAILABLE" "cgreen"
        pprint "\n\nDo you want to automatically upgrade (y/n)?"
        if yesnoprompt; then
            pprint "\n\nUpgrading packages.. "
            sudo apt upgrade -y &>/dev/null &&
            pprint "DONE!\n\n" "cgreen" || (pprint "FAIL.\n\n" "cred"; exit 1)
        else
            echo
        fi
    else
        pprint "ALREADY UP TO DATE\n\n" "cgreen"
    fi
}

packages(){
    if ! command -v pip &>/dev/null; then
        pprint "pip not found, installing.. "
        sudo apt install python3-pip -y 2>pypilog.txt 1>/dev/null &&
        pprint "SUCCESS.\n\n" "cgreen" || (pprint "FAIL.\n\n" "cred"; exit 1)
    fi

    if ! command -v ffmpeg &>/dev/null; then
        pprint "ffmpeg not found, installing.. "
        if sudo apt install ffmpeg -y &>/dev/null; then
            pprint "SUCCESS.\n\n" "cgreen"
        else
            pprint "FAIL.\n\n" "cred"
            pprint "ffmpeg is required. Please install it manually.\n" "cblue"
            exit 1
        fi
    fi
}

installation(){
    pprint "\n\nInstalling dependencies.. "
    pip3 install -U pip &>>pypilog.txt &&
    pip3 install -U -r requirements.txt &>>pypilog.txt &&
    pprint "DONE.\n" "cgreen" && return
    pprint "FAIL.\n" "cred"
    exit 1
}

clear
pprint "Welcome to Shinobu Music Bot Setup\n\n"
pprint "If you see errors during installation, check these log files:"
pprint "\nPyPI errors: pypilog.txt\n"
sleep 2
pprint "\n\nScript needs sudo privileges to install packages.\n"
sudo test

update
packages
installation

pprint "\n\n\nShinobu Music Bot installation complete!" "cgreen"
sleep 2
clear

pprint "\nEnter your config values below\n\n\n"
pprint "API ID: "; color_reset; read api_id
pprint "\nAPI HASH: "; color_reset; read api_hash
pprint "\nBOT TOKEN: "; color_reset; read bot_token
pprint "\nMONGO DB URI: "; color_reset; read mongo_db
pprint "\nLOG GROUP ID: "; color_reset; read logger
pprint "\nOWNER ID: "; color_reset; read ownid
pprint "\nMUSIC BOT NAME: "; color_reset; read mbt
pprint "\nSTRING SESSION: "; color_reset; read string_session

pprint "\n\nSaving your config.." "cgreen"

if [ -f .env ]; then
    rm .env
fi

echo """API_ID=$api_id
API_HASH=$api_hash
BOT_TOKEN=$bot_token
MONGO_DB_URI=$mongo_db
LOG_GROUP_ID=$logger
OWNER_ID=$ownid
MUSIC_BOT_NAME=$mbt
STRING_SESSION=$string_session""" > .env

clear
pprint "\n\n\nConfig saved successfully!\n\nStart the bot with: bash start\n\n"
pprint "For additional vars, check sample.env and README.md\n\n"